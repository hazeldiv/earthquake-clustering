{
  "pythonVersion": "3.12",
  "buildCommand": "uv pip install --system -r requirements.txt",
  "installCommand": "uv pip install --system -r requirements.txt",
  "devCommand": "uvicorn backend.main:app --reload --port $PORT",
  "routes": [
    {
      "src": "/(.*)",
      "dest": "backend/main.py"
    }
  ]
}
